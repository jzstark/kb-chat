GITHUB_OWNER=your-github-owner

# Public URL served by this stack.
LIBRECHAT_DOMAIN_CLIENT=https://chat.laughtale.co.uk
LIBRECHAT_DOMAIN_SERVER=https://chat.laughtale.co.uk

# Remote KnowledgeBase-S API used by kb-mcp.
KB_API_BASE=https://swanny.laughtale.co.uk
KB_SERVICE_TOKEN=change_me_after_kb_api_supports_service_tokens

# Model provider keys used by LibreChat.
CLAUDE_API_KEY=
OPENAI_API_KEY=

# Brave Search API key used by search-mcp.
BRAVE_SEARCH_API_KEY=

# LibreChat secrets. Generate strong random values before deployment.
LIBRECHAT_JWT_SECRET=change_me_lc_jwt
LIBRECHAT_JWT_REFRESH_SECRET=change_me_lc_refresh
LIBRECHAT_CREDS_KEY=change_me_creds_key
LIBRECHAT_CREDS_IV=change_me_creds_iv
MEILI_MASTER_KEY=change_me_meili_key

# Temporarily set to true only when creating the first account.
ALLOW_REGISTRATION=false
